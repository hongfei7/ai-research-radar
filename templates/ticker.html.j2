<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ ticker_name }}（{{ ticker }}）— AI 投研雷达</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f5f7fa; color: #1a1a2e; line-height: 1.6; }
    .container { max-width: 800px; margin: 0 auto; padding: 20px; }
    header { background: linear-gradient(135deg, #1a1a2e, #16213e); color: #fff; padding: 30px 20px; text-align: center; }
    header h1 { font-size: 1.8em; }
    header a { color: #e94560; }
    .back { margin: 16px 0; }
    .back a { color: #1a73e8; text-decoration: none; }
    .section { margin: 20px 0; }
    .section h2 { font-size: 1.2em; color: #16213e; margin-bottom: 12px; padding-bottom: 8px; border-bottom: 2px solid #e94560; }
    .event-card, .item-row { background: #fff; border-radius: 8px; padding: 16px; margin-bottom: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
    .event-card h3 { font-size: 1.05em; margin-bottom: 6px; }
    .event-card .summary { color: #555; font-size: 0.92em; }
    .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
    .tag { padding: 2px 10px; border-radius: 12px; font-size: 0.78em; }
    .tag-theme { background: #fce8e6; color: #e94560; }
    .direction-positive { color: #137333; font-weight: 600; }
    .direction-negative { color: #c5221f; font-weight: 600; }
    .direction-neutral { color: #666; }
    .item-row .meta { font-size: 0.82em; color: #888; margin-top: 4px; }
    footer { text-align: center; color: #999; font-size: 0.82em; padding: 20px; }
  </style>
</head>
<body>
  <header>
    <h1>{{ ticker_name }} {% if ticker %}（{{ ticker }}）{% endif %}</h1>
    <p><a href="{{ site_url }}/">← 返回实时看板</a></p>
  </header>

  <div class="container">
    <div class="section">
      <h2>相关事件 ({{ events | length }})</h2>
      {% for evt in events %}
      <div class="event-card">
        <h3>{{ evt.title }}</h3>
        <div class="summary">{{ evt.summary }}</div>
        <div class="tags">
          {% for th in evt.themes %}
          <span class="tag tag-theme">{{ th }}</span>
          {% endfor %}
        </div>
        {% if evt.direction and ticker_name in evt.direction %}
        <div style="margin-top:6px;">
          方向: <span class="direction-{{ evt.direction[ticker_name] }}">{{ evt.direction[ticker_name] }}</span>
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>

    <div class="section">
      <h2>最近条目 ({{ items | length }})</h2>
      {% for item in items %}
      <div class="item-row">
        <strong>[{{ item.relevance_score }}分]</strong>
        <a href="{{ item.url }}" target="_blank">{{ item.title }}</a>
        <div>{{ item.cn_summary }}</div>
        <div class="meta">{{ item.published_at }} · {{ item.source }} {% if item.credibility %}{{ cred_emoji(item.credibility) }}{% endif %}{% if not item.is_primary_source %} ⛓️转载{% endif %}</div>
      </div>
      {% endfor %}
    </div>
  </div>

  <footer>AI 投研雷达 · 仅作为研究输入素材，不构成投资建议</footer>
</body>
</html>
